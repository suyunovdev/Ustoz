# ─── Database ──────────────────────────────────────────────────────────────
# PostgreSQL — Prisma 7 + pg adapter
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ustoz_db"

# ─── Auth ──────────────────────────────────────────────────────────────────
# JWT secret — 32+ tasodifiy belgi
# Generate: openssl rand -base64 48
JWT_SECRET="your-super-secret-jwt-key-here"

# ─── Public URLs ───────────────────────────────────────────────────────────
# Frontend uchun (auth callback, sharing va h.k.)
NEXT_PUBLIC_APP_URL=http://localhost:4028
# SEO uchun — sitemap.xml va robots.txt'da ishlatiladi
NEXT_PUBLIC_SITE_URL=http://localhost:4028

# ─── Payment (Click & Payme) ───────────────────────────────────────────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_KEY=

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── AI (ixtiyoriy) ────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

